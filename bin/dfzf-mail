#!/usr/bin/env bash
set -euo pipefail

export SHELL="$(command -v bash)"
dfzf-kill-bro >/dev/null
export FZF_DEFAULT_OPTS="--ansi --no-sort --exact --cycle --color=gutter:-1 --header= --info=inline-right --margin=1,2"

# Shared state file with `dfzf-mail-load`. Stores the currently selected
# folder + page + query so that fzf `reload(dfzf-mail-load)` keeps context
# across reloads (fzf binds cannot pass arguments to the reload command).
state_file="${DFZF_MAIL_STATE:-${XDG_RUNTIME_DIR:-/tmp}/dfzf-mail.state}"
export DFZF_MAIL_STATE="$state_file"

# Reset state on each launch: defaults to INBOX, page 1, page-size 50, no query.
cat >"$state_file" <<-EOF
	folder="INBOX"
	page=1
	page_size=50
	query=""
	help=0
EOF

dfzf-mail-load |
	fzf --prompt "Mail [INBOX p1] > " \
		--bind="?:transform-header(dfzf-mail-state help-toggle)" \
		--preview-window="up:wrap" \
		--preview="id=\$(echo {}| sed -Ez 's/.*#([0-9]+).*/\1/'); himalaya message read -f \"\$(dfzf-mail-state folder)\" \"\$id\"" \
		--bind="ctrl-k:execute-silent(id=\$(echo {}| sed -Ez 's/.*#([0-9]+).*/\1/'); himalaya message delete -f \"\$(dfzf-mail-state folder)\" \"\$id\")+reload(dfzf-mail-load)" \
		--bind="ctrl-j:execute-silent(id=\$(echo {}| sed -Ez 's/.*#([0-9]+).*/\1/'); dir=\$(mktemp -d -t dfzf-mail-XXXXXX); himalaya message export -f \"\$(dfzf-mail-state folder)\" -O -d \"\$dir\" \"\$id\")+accept" \
		--bind="ctrl-d:execute-silent(id=\$(echo {}| sed -Ez 's/.*#([0-9]+).*/\1/'); himalaya attachment download -f \"\$(dfzf-mail-state folder)\" \"\$id\" >/dev/null 2>&1)" \
		--bind=">:execute-silent(dfzf-mail-state next-page)+reload(dfzf-mail-load)+transform-prompt(dfzf-mail-state prompt)" \
		--bind="<:execute-silent(dfzf-mail-state prev-page)+reload(dfzf-mail-load)+transform-prompt(dfzf-mail-state prompt)" \
		--bind="ctrl-f:execute(dfzf-mail-state pick-folder </dev/tty >/dev/tty)+reload(dfzf-mail-load)+transform-prompt(dfzf-mail-state prompt)" \
		--bind="ctrl-o:execute(id=\$(echo {}| sed -Ez 's/.*#([0-9]+).*/\1/'); dfzf-mail-state move \"\$id\" </dev/tty >/dev/tty)+reload(dfzf-mail-load)" \
		--bind="ctrl-s:execute(dfzf-mail-state search </dev/tty >/dev/tty)+reload(dfzf-mail-load)+transform-prompt(dfzf-mail-state prompt)" \
		--bind="ctrl-r:execute-silent(id=\$(echo {}| sed -Ez 's/.*#([0-9]+).*/\1/'); folder=\$(dfzf-mail-state folder); setsid -f \${DFZF_TERM:-kitty -1 -e} dfzf-mail-reply \"\$folder\" \"\$id\")+abort" \
		--bind="ctrl-w:execute-silent(setsid -f \${DFZF_TERM:-kitty -1 -e} dfzf-mail-write)+abort" \
		--bind="ctrl-alt-r:execute-silent(id=\$(echo {}| sed -Ez 's/.*#([0-9]+).*/\1/'); folder=\$(dfzf-mail-state folder); setsid -f \${DFZF_TERM:-kitty -1 -e} dfzf-mail-reply \"\$folder\" \"\$id\" --all)+abort"
