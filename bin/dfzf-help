#!/usr/bin/env bash
set -euo pipefail

# Single source of truth for the per-tool keybinding cheatsheets shown by the
# `?` key. fzf has no built-in keybinding listing, so each dfzf tool binds
# `?:transform-header(dfzf-help toggle <tool>)` and we keep the text here.
#
# Usage:
#   dfzf-help toggle <tool>   flip the persisted help flag for <tool> and print
#                             its cheatsheet (or nothing when toggled off).
#                             Bound to `?` via fzf's `transform-header`.
#   dfzf-help reset <tool>    force the flag to hidden (called on launch so the
#                             cheatsheet starts hidden each session).
#   dfzf-help show <tool>     print the cheatsheet unconditionally.
#
# Whenever a tool's bindings change, update its entry in `cheatsheet` below.

state_dir="${XDG_RUNTIME_DIR:-/tmp}"

cheatsheet() {
	case "$1" in
	mail)
		printf '%s' $'? help · ◂ ▸ prev/next page\nenter export · ctrl-j read html · ctrl-d download attachments\nctrl-l folder · ctrl-s search · ctrl-o move\nctrl-w write · ctrl-r reply · ctrl-alt-r reply all · ctrl-f forward · ctrl-k delete'
		;;
	windows)
		printf '%s' $'? help · enter focus · esc cancel · ctrl-t tile together\nctrl-r/b/g/o mark red/blue/green/orange · R/G/B filter by color\nctrl-k kill · ctrl-u toggle urgent · ctrl-h toggle hidden · ctrl-j preview'
		;;
	tasks)
		printf '%s' $'? help · ctrl-e edit · ctrl-d done · ctrl-k delete\nctrl-l switch collection · ctrl-t new task · ctrl-r sync'
		;;
	clipboard)
		printf '%s' $'? help · enter paste · y copy (keep open) · ctrl-k delete'
		;;
	password)
		printf '%s' $'? help · enter copy password · ctrl-j toggle preview'
		;;
	*)
		return 1
		;;
	esac
}

cmd="${1:-}"
tool="${2:-}"
[[ -z $tool ]] && {
	echo "usage: dfzf-help {toggle|reset|show} <tool>" >&2
	exit 2
}

flag_file="$state_dir/dfzf-help.$tool"

case "$cmd" in
show)
	cheatsheet "$tool"
	;;
reset)
	rm -f "$flag_file"
	;;
toggle)
	if [[ -e $flag_file ]]; then
		rm -f "$flag_file"
	else
		: >"$flag_file"
		cheatsheet "$tool"
	fi
	;;
*)
	echo "usage: dfzf-help {toggle|reset|show} <tool>" >&2
	exit 2
	;;
esac
