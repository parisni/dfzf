#!/usr/bin/env bash
set -euo pipefail

# Helper invoked from `dfzf-mail` fzf bindings to mutate the shared state
# file (folder/page/page-size/query) and to compute the dynamic prompt.
#
# Subcommands:
#   next-page     increment current page (clamped on himalaya error is left
#                 to the user: ctrl-p brings them back).
#   prev-page     decrement current page, clamped to 1.
#   pick-folder   open a nested fzf to pick a folder from `himalaya folder
#                 list`; resets page to 1 and clears the search query (a
#                 search is mentally tied to a folder).
#   pick-move-folder
#                 same nested fzf picker as `pick-folder`, but only prints the
#                 chosen folder name to stdout without touching the view state
#                 (used by `dfzf-mail`'s ctrl-o to pick a move target).
#   search        prompt for a himalaya search query, store it and reset to
#                 page 1; an empty query clears the filter.
#   prompt        print the dynamic fzf prompt based on current state.
#   folder        print the currently selected folder (used by the reply
#                 binding which needs to pass `-f <folder>` to himalaya).

state_file="${DFZF_MAIL_STATE:-${XDG_RUNTIME_DIR:-/tmp}/dfzf-mail.state}"

folder="INBOX"
page=1
page_size=50
query=""
if [[ -r $state_file ]]; then
	# shellcheck disable=SC1090
	source "$state_file"
fi

save_state() {
	cat >"$state_file" <<-EOF
		folder="${folder}"
		page=${page}
		page_size=${page_size}
		query="${query}"
	EOF
}

# Shared nested fzf folder picker. Prints the selected folder name (empty if
# the user aborts). Reused by `pick-folder` (changes the view) and
# `pick-move-folder` (move target), so the listing/UI stays in one place.
pick_folder() {
	RUST_LOG=off himalaya folder list -o json |
		jq -r '.[] | .name' |
		fzf --prompt "${1:-Folder > }" --no-preview --height=40% --reverse
}

case "${1:-}" in
next-page)
	page=$((page + 1))
	save_state
	;;
prev-page)
	if ((page > 1)); then
		page=$((page - 1))
	fi
	save_state
	;;
pick-folder)
	picked="$(pick_folder "Folder > ")" || exit 0
	[[ -z $picked ]] && exit 0
	folder="$picked"
	page=1
	query=""
	save_state
	;;
pick-move-folder)
	# Stateless variant: print the chosen folder so the caller can pass it as
	# `himalaya message move`'s target. Does not mutate the current view.
	pick_folder "Move to > " || exit 0
	;;
search)
	# fzf with an empty list acts as a free-text input; --print-query
	# echoes whatever was typed. The header documents himalaya's query
	# syntax so the user does not have to remember it.
	header=$'Query: subject|body|from|to <txt> · before|after <yyyy-mm-dd> · flag <f> · and/or/not · order by date desc\nEx: from enedis and subject facture    |    body rdv after 2026-01-01 order by date desc\nEmpty query clears the search.'
	# `set -e` aborts the whole script when a command substitution exits
	# non-zero, and fzf exits 1 when Enter is pressed on an empty list. Run
	# fzf on its own line guarded by `|| rc=$?` so the typed query survives;
	# only esc/ctrl-c (130) is treated as a real abort.
	rc=0
	typed="$(: | fzf --prompt "Search > " --print-query --no-preview \
		--height=40% --reverse --header="$header" --query="$query" \
		--bind="enter:print-query+accept")" || rc=$?
	[[ $rc -eq 130 ]] && exit 0
	query="$(printf '%s' "$typed" | head -n1)"
	page=1
	save_state
	;;
prompt)
	if [[ -n $query ]]; then
		printf 'Mail [%s 🔍 p%s] > ' "$folder" "$page"
	else
		printf 'Mail [%s p%s] > ' "$folder" "$page"
	fi
	;;
folder)
	printf '%s' "$folder"
	;;
*)
	echo "usage: dfzf-mail-state {next-page|prev-page|pick-folder|pick-move-folder|search|prompt|folder}" >&2
	exit 2
	;;
esac
